---
import { Splide, SplideSlide } from 'astro-splide';
import { Tweet, Vimeo, YouTube } from 'astro-embed';

import '@splidejs/splide/dist/css/themes/splide-default.min.css';
import '@splidejs/react-splide/css';
---

<div class="how-it-works">
  <div class="container text-center sm:p-24 px-4 py-20" id="our-products">
    <div class="h2">Our Products</div>

    <p class="text-lg text-byline mt-4 max-w-3xl mx-auto">
      <b>Makeshift Software Inc.</b> is a software venture studio developing products across social networking, local commerce, and games, including <b>Senpai</b>, <b>ThunderTruck</b>, and <b>Makeshift Games</b>.
    </p>
  </div>

  <div class="container px-4 pb-20 pl-20 pr-20 relative">
    <Splide
      options={{
        type: 'loop',
        perPage: 1,
        perMove: 1,
        gap: '1rem',
        pagination: true,
        arrows: true,
        autoplay: false,
        breakpoints: {
          640: {
            perPage: 1,
            gap: '1rem',
          },
          768: {
            perPage: 2,
            gap: '1.5rem',
          },
          1024: {
            perPage: 3,
            gap: '2rem',
          },
        },
      }}
      aria-label="Service Tiers"
    >
      <!-- Senpai -->
      <SplideSlide>
        <div class="bg-[dimgrey] backdrop-blur-sm rounded-xl shadow-lg border-2 border-[whitesmoke] p-6 h-full flex flex-col max-w-sm mx-auto">
          <div class="text-center mb-4">
            <div class="inline-flex items-center justify-center mb-6">
              <img
                src="/assets/images/senpai_logo.png"
                alt="Senpai logo"
                class="h-16 w-16 max-w-full object-contain sm:h-20 sm:w-20 md:h-24 md:w-24"
              />
            </div>
            <h3 class="text-xl sm:text-2xl text-white font-bold mb-1">Senpai</h3>
            <h4 class="text-base sm:text-lg font-semibold text-[#FEFEFE] mb-1">Anime Social & Dating</h4>
          </div>

          <div class="flex-1 space-y-3 sm:space-y-4">
            <p class="text-xs text-[0.9rem] sm:text-sm md:text-base text-white tracking-[0.3px] leading-[1.4]">
              Senpai is an anime-focused social networking and dating app built for fans who want to connect through shared fandom, personality, and avatar-based interaction.
            </p>
            <p class="text-xs text-[0.9rem] sm:text-sm md:text-base text-white tracking-[0.3px] leading-[1.4]">
              The platform combines anime dating, social discovery, and creator-driven content, giving users a dedicated space to meet other fans, chat, match, and express themselves through anime-inspired profiles and digital identity.
            </p>
          </div>

          <a
            href="https://apps.apple.com/us/app/senpai-dating-for-anime-fans/id6464066826"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 block w-full rounded-lg bg-white px-6 py-3 text-center text-sm font-semibold text-gray-900 transition hover:bg-gray-100 sm:text-base"
          >
            Visit Senpai
          </a>
        </div>
      </SplideSlide>

      <!-- Tier 2 -->
      <SplideSlide>
        <div class="bg-[#FCA211] backdrop-blur-sm rounded-xl shadow-lg border-2 border-[#DB6800] p-6 h-full flex flex-col relative max-w-sm mx-auto">
          <div class="text-center mb-4">
            <div class="inline-flex items-center justify-center mb-6">
              <img
                src="/assets/images/thundertruck_logo.png"
                alt="ThunderTruck Logo"
                class="h-16 w-16 max-w-full object-contain sm:h-20 sm:w-20 md:h-24 md:w-24"
              />
            </div>

            <h3 class="text-xl sm:text-2xl text-white font-bold mb-1">ThunderTruck</h3>
            <h4 class="text-base sm:text-lg font-semibold text-[#FEFEFE] mb-1">Food Delivery</h4>
          </div>          

          <div class="flex-1 space-y-3 sm:space-y-4">
            <p class="text-xs text-[antiquewhite] text-[0.9rem] font-semibold sm:text-sm md:text-base text-white tracking-[0.3px] leading-[1.4]">
              Experience the best authentic cuisines from local restaurants, delivered straight to your doorstep. Fresh, fast, and full of flavor.
            </p>
            <p class="text-xs text-[antiquewhite] text-[0.9rem] font-semibold sm:text-sm md:text-base text-white tracking-[0.3px] leading-[1.4]">
              The platform combines anime dating, social discovery, and creator-driven content, giving users a dedicated space to meet other fans, chat, match, and express themselves through anime-inspired profiles and digital identity.
            </p>
          </div>

          <a
            href="https://senpaiapp.com"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 block w-full rounded-lg bg-[#DB6800] px-6 py-3 text-center text-sm text-[antiquewhite] font-semibold text-gray-900 transition hover:bg-[#af5300] sm:text-base"
          >
            Visit ThunderTruck™
          </a>
        </div>
      </SplideSlide>

      <!-- Tier 3 -->
      <SplideSlide>
        
        <div class="bg-[rgba(139,0,0,0.9)] backdrop-blur-sm rounded-xl shadow-lg border-2 border-[#2a0000] p-6 h-full flex flex-col relative max-w-sm mx-auto">
          <div class="text-center mb-4">
            <div class="inline-flex items-center justify-center">
              <img
                src="/assets/images/makeshift-logo-cropped.png"
                alt="Makeshift Logo"
                class="max-w-full object-contain w-40 h-8 mt-6 mx-4 mb-2 sm:w-48 sm:h-10 sm:mt-8 sm:mx-8 sm:mb-3 md:w-56 md:h-12 md:mt-12 md:mx-12 md:mb-4"
              />
            </div>

            <h3 class="text-xl sm:text-2xl text-white font-bold mb-1">Makeshift Games</h3>
            <h4 class="text-base sm:text-lg font-semibold text-[#FEFEFE] mb-1">Play Anywhere</h4>
          </div>          

          <div class="flex-1 space-y-3 sm:space-y-4">
            <p class="text-xs text-[lightcoral] text-[0.9rem] font-semibold sm:text-sm md:text-base text-white tracking-[0.2px] leading-[1.4]">
              Makeshift Games develops original titles for PC, console, and mobile, bringing immersive worlds and bold gameplay to players on every major platform.
            </p>
            <p class="text-xs text-[lightcoral] text-[0.9rem] font-semibold sm:text-sm md:text-base text-white tracking-[0.2px] leading-[1.4]">
              From early prototypes to polished releases, our studio builds games designed to be played anywhere — at your desk, on the couch, or on the go.
            </p>
          </div>

          <a
            href="/our-games"
            class="mt-4 block w-full rounded-lg bg-[#540101] px-6 py-3 text-center text-sm text-[antiquewhite] font-semibold transition hover:bg-[#930101] sm:text-base"
          >
            View Our Games
          </a>
        </div>
      </SplideSlide>
    </Splide>
  </div>
</div>

<style>
  :global(.splide__arrow) {
    background: #D20202;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    opacity: 0.9;
    position: absolute;
    z-index: 10;
    top: 50%;
    transform: translateY(-50%);
  }
  
  :global(.splide__arrow--prev) {
    left: -60px;
  }
  
  :global(.splide__arrow--next) {
    right: -60px;
  }
  
  :global(.splide__arrow:hover) {
    background: white;
    opacity: 1;
  }
  
  :global(.splide__pagination) {
    bottom: -2.5em !important;
  }
  
  :global(.splide__pagination__page) {
    background: #d1d5db;
    width: 10px;
    height: 10px;
  }
  
  :global(.splide__pagination__page.is-active) {
    background: #D20202;

  }
  
  :global(.splide__slide) {
    padding: 0.5rem;
  }

  :global(.text-byline)
  {
    font-weight: 300;
    color: whitesmoke;
    line-height: 1.8;
  }

  /* Companies Scrolling Section */
  .companies-scroll-container {
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .companies-scroll {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 2rem 0;
    animation: scroll 18s linear infinite;
    width: max-content;
  }

  .company-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 150px;
    height: 80px;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .company-logo:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #D20202;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(210, 2, 2, 0.2);
  }

  .company-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: brightness(0.9) contrast(1.1);
    transition: filter 0.3s ease;
  }

  .company-logo:hover .company-img {
    filter: brightness(1) contrast(1);
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pause animation on hover */
  .companies-scroll-container:hover .companies-scroll {
    animation-play-state: paused;
  }

  /* Book Now Button */
  .book-now-btn {
    display: inline-block;
    background: #D20202;
    color: whitesmoke;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid #D20202;
    box-shadow: 0 4px 15px rgba(210, 2, 2, 0.3);
  }

  .book-now-btn:hover {
    background: transparent;
    color: #D20202;
    border-color: #D20202;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(210, 2, 2, 0.4);
  }

  .book-now-btn:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .companies-scroll {
      gap: 2rem;
      animation-duration: 20s;
    }
    
    .company-logo {
      min-width: 120px;
      height: 60px;
      padding: 0.75rem;
    }
  }
  
  /* Responsive Splide arrows */
  @media (max-width: 1024px) {
    :global(.splide__arrow--prev) {
      left: -50px;
    }
    
    :global(.splide__arrow--next) {
      right: -50px;
    }
  }
  
  @media (max-width: 768px) {
    :global(.splide__arrow--prev) {
      left: -40px;
    }
    
    :global(.splide__arrow--next) {
      right: -40px;
    }
    
    :global(.splide__arrow) {
      width: 35px;
      height: 35px;
    }
  }
  
  @media (max-width: 640px) {
    :global(.splide__arrow--prev) {
      left: -30px;
    }
    
    :global(.splide__arrow--next) {
      right: -30px;
    }
    
    :global(.splide__arrow) {
      width: 30px;
      height: 30px;
    }
  }
  
  @media (max-width: 480px) {
    :global(.splide__arrow--prev) {
      left: -25px;
    }
    
    :global(.splide__arrow--next) {
      right: -25px;
    }
    
    :global(.splide__arrow) {
      width: 28px;
      height: 28px;
    }
  }
</style>
