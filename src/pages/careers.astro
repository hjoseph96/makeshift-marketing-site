---
import Footer from "~/components/Footer.astro";
import Layout from "~/layouts/Layout.astro";
const metadata = {
    title: 'Careers | Makeshift Software Inc.',
    ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <main>
    <div class="container sm:py-28 py-16 px-4">
      <h1 class="h2 text-center">Careers</h1>
      <p class="caption1 mt-8 text-center">
        We're always looking for talented people to join the Makeshift team.
      </p>

      <div class="mt-16">
        <script src="https://www.workable.com/assets/embed.js" type="text/javascript"></script>
        <script type="text/javascript" charset="utf-8">
          /* global whr, whr_embed */
          whr(document).ready(() => {
            whr_embed(738061, {"base":"jobs","zoom":"country","grouping":"departments"});
          });
        </script>
        <div id="whr_embed_hook"></div>
      </div>
    </div>
    <hr class="color-white opacity-10" />
    <Footer />
  </main>
</Layout>

<style>
  /* Workable embed — uses :global() because markup is injected at runtime */

  :global(#whr_embed_hook) {
    max-width: 860px;
    margin: 0 auto;
  }

  /* Department group heading */
  :global(.whr-group) {
    font-family: Lato, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #D20202;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(210, 2, 2, 0.25);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  /* Job list */
  :global(.whr-items) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Individual job card */
  :global(.whr-item) {
    background: #1A1D28;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  :global(.whr-item:hover) {
    border-color: rgba(210, 2, 2, 0.45);
    background: #1e2130;
  }

  /* Job title link */
  :global(.whr-title) {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
  }

  :global(.whr-title a) {
    font-family: Lato, sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: whitesmoke;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  :global(.whr-title a:hover) {
    color: #D20202;
    text-decoration: underline;
  }

  /* Metadata row (location, date) */
  :global(.whr-info) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.5rem;
  }

  :global(.whr-info li) {
    font-family: Lato, sans-serif;
    font-size: 0.8rem;
    color: #A9AFC2;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  :global(.whr-info li span) {
    color: #5B6277;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.7rem;
  }

  /* Workable "powered by" footer link */
  :global(.whr-powered) {
    margin-top: 2.5rem;
    text-align: center;
    font-size: 0.75rem;
    color: #5B6277;
  }

  :global(.whr-powered a) {
    color: #5B6277;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  :global(.whr-powered a:hover) {
    color: whitesmoke;
  }
</style>
